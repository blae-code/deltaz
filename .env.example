# Required for local Base44 app access
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Optional: use a specific deployed function version when testing backend rollouts
VITE_BASE44_FUNCTIONS_VERSION=

# Backend deployment contract for authoritative world-state sync
# Configure one of the following in the deployed Base44 function environment:
# WORLD_STATE_FILE_PATH=/path/to/world-state.json
# WORLD_STATE_RCON_COMMAND=YourWorldStateCommand

# Optional backend deployment secret for signed external ops-log ingestion
# OPS_LOG_WEBHOOK_SECRET=replace_with_a_long_random_secret
